{
  "framework": null,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/bundle.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ]
}
